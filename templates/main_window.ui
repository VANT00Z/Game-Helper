            <property name="styleSheet">
                <string notr="true">
                    QMenuBar {
                    background: #ffffff;
                    color: #4a5568;
                    font-size: 14px;
                    font-weight: 600;
                    padding: 4px;
                    border-bottom: 1px solid #e2e8f0;
                    }
                    QMenuBar::item {
                    padding: 6px 16px;
                    border-radius: 8px;
                    background: transparent;
                    margin: 2px;
                    }
                    QMenuBar::item:selected {
                    background: #edf2f7;
                    color: #5a67d8;
                    }
                    QMenuBar::item:pressed {
                    background: #e2e8f0;
                    color: #4c51bf;
                    }
                    QMenu {
                    background: #ffffff;
                    color: #4a5568;
                    border: 1px solid #e2e8f0;
                    border-radius: 12px;
                    padding: 8px;
                    }
                    QMenu::item {
                    padding: 10px 40px;
                    border-radius: 8px;
                    background: transparent;
                    }
                    QMenu::item:selected {
                    background: #edf2f7;
                    color: #5a67d8;
                    }
                    QMenu::item:pressed {
                    background: #e2e8f0;
                    color: #4c51bf;
                    }
                    QMenu::separator {
                    height: 1px;
                    background: #e2e8f0;
                    margin: 6px 15px;
                    }
                </string>
            </property>
            <widget class="QMenu" name="menu">
                <property name="title">
